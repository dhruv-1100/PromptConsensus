# ConsensusPrompt - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API key (used for Agent A, Agent C, and as fallback target LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (used for Agent B, Arbitrator, and Intent Extractor)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API key (used for Gemini models)
GOOGLE_API_KEY=your_google_api_key_here
